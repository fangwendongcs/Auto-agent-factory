{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/result.schema.json",
  "title": "Agent Result",
  "description": "Structured executor output consumed by the criteria checker workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "task_id",
    "status",
    "summary",
    "artifacts",
    "known_issues",
    "evidence",
    "next_action_suggestion"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^gd_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "failed",
        "needs_human_approval"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "known_issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterion",
          "status",
          "detail"
        ],
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "unknown"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Executor-side evidence that the checker may verify or challenge."
    },
    "next_action_suggestion": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "default": null
    }
  }
}

