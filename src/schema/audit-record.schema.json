{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/audit-record.schema.json",
  "title": "Sanitized Audit Run Record",
  "description": "Sanitized run record for staging-style audit logging. It must not contain secrets, raw prompts, Authorization headers, or full provider responses.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_record_version",
    "run_id",
    "task_id",
    "record_type",
    "created_at",
    "status",
    "goal_summary",
    "criteria_count",
    "risk_level",
    "action_class",
    "permission_level",
    "provider",
    "approval_decision",
    "timestamps",
    "storage",
    "safety",
    "redaction"
  ],
  "properties": {
    "audit_record_version": {
      "type": "string",
      "enum": ["v0.8b-sanitized-audit-record"]
    },
    "run_id": {
      "type": "string",
      "pattern": "^gd_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "record_type": {
      "type": "string",
      "enum": ["sanitized_run_record"]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "goal_summary": {
      "type": "string",
      "minLength": 1
    },
    "criteria_count": {
      "type": "integer",
      "minimum": 0
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "action_class": {
      "type": "string",
      "enum": [
        "read_only",
        "local_draft",
        "repo_write",
        "shell_command",
        "git_operation",
        "external_write",
        "deployment"
      ]
    },
    "permission_level": {
      "type": "string",
      "enum": ["read_only", "draft", "write_action", "forbidden"]
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "name", "model", "status"],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": ["string", "null"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "status": {
          "type": ["string", "null"]
        }
      }
    },
    "approval_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "blocked", "approved", "requires_human_approval"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["allow", "approved", "needs_human_approval", "forbidden", "invalid_request", "rejected"]
        },
        "blocked": {
          "type": "boolean"
        },
        "approved": {
          "type": "boolean"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "reason_summary": {
          "type": ["string", "null"]
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "finished_at"],
      "properties": {
        "started_at": {
          "type": ["string", "null"]
        },
        "finished_at": {
          "type": ["string", "null"]
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "persisted"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["mock_repo_contract"]
        },
        "persisted": {
          "type": "boolean"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_write_default", "side_effects_enabled", "raw_prompt_stored", "raw_provider_response_stored", "secrets_stored"],
      "properties": {
        "no_write_default": {
          "type": "boolean"
        },
        "side_effects_enabled": {
          "type": "boolean"
        },
        "raw_prompt_stored": {
          "type": "boolean"
        },
        "raw_provider_response_stored": {
          "type": "boolean"
        },
        "secrets_stored": {
          "type": "boolean"
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applied", "excluded_fields"],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "excluded_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
