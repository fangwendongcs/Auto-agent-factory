{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/task.schema.json",
  "title": "Agent Task",
  "description": "A single executor task produced inside one Goal-Driven workflow run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "task_id",
    "goal",
    "criteria",
    "iteration",
    "instruction",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^gd_[A-Za-z0-9_-]+$",
      "description": "Stable identifier for the full goal-driven run."
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$",
      "description": "Identifier for this specific executor task."
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "iteration": {
      "type": "integer",
      "minimum": 1,
      "description": "Current executor/checker iteration number."
    },
    "max_iterations": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "default": 5
    },
    "timeout_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30,
      "default": 30
    },
    "instruction": {
      "type": "string",
      "minLength": 1,
      "description": "The concrete instruction for this round of agent work."
    },
    "previous_feedback": {
      "type": "string",
      "default": "",
      "description": "Optional prior checker feedback used in follow-up iterations."
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "low"
    },
    "requires_human_approval": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "dispatched",
        "in_progress",
        "completed",
        "failed",
        "needs_human_approval"
      ]
    }
  }
}

